# Copy to .env in this folder — NEVER commit .env
# ASP.NET Core maps Cloudflare__AccountId → Cloudflare:AccountId

# --- API public URL (for R2 upload links, webhooks) ---
Api__PublicBaseUrl=https://unimarket-api.youngfuturetechnology.xyz

# --- Local dev only (when D1 is disabled) ---
ConnectionStrings__Default=Data Source=data/unimarket.db

# --- Firebase Auth (server-side token verification) ---
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json
Firebase__ProjectId=your-firebase-project-id
Firebase__Enabled=false

# --- Cloudflare D1 (PRIMARY database — all app records live here) ---
Cloudflare__AccountId=your_cloudflare_account_id
Cloudflare__D1DatabaseId=your_unimarket-db_uuid
Cloudflare__D1ApiToken=your_d1_api_token
Cloudflare__D1Enabled=true

# --- Cloudflare R2 (object storage — required for seller ID & listing photos) ---
# Dashboard → R2 → Create bucket "unimarket-assets" → Manage Public Access → r2.dev URL
# Dashboard → R2 → Manage R2 API Tokens → Create token (Object Read & Write)
Cloudflare__R2Enabled=true
Cloudflare__R2AccessKeyId=your_r2_access_key_id
Cloudflare__R2SecretAccessKey=your_r2_secret_access_key
Cloudflare__R2BucketName=unimarket-assets
Cloudflare__R2Endpoint=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
Cloudflare__R2PublicBaseUrl=https://pub-YOUR_BUCKET_ID.r2.dev
# Dev-only when R2 keys are not set yet (saves to data/uploads/, served at /media):
Cloudflare__AllowLocalUploadFallback=false

# --- Admin review queue (Cloudflare Worker / internal tools) ---
# Must match ADMIN_API_KEY secret on the deployed worker.
Admin__ApiKey=change-me-to-a-long-random-secret
Cloudflare__AiReviewUrl=https://unimarket-admin.unimarket93.workers.dev/api/ai-review

# --- Resend (campus email OTP for seller applications) ---
Resend__ApiKey=re_your_resend_api_key
Resend__FromAddress=UniMarket <noreply@your-verified-domain.com>
Resend__Enabled=true
