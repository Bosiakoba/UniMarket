# Copy to .env in this folder — NEVER commit .env
# ASP.NET Core maps Cloudflare__AccountId → Cloudflare:AccountId

# --- Persistent database (SQLite file, D1-compatible schema) ---
ConnectionStrings__Default=Data Source=data/unimarket.db
Api__PublicBaseUrl=http://192.168.0.165:5080

# --- Firebase Auth (server-side token verification) ---
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json
Firebase__ProjectId=your-firebase-project-id
Firebase__Enabled=false

# --- Cloudflare D1 (SQLite) ---
Cloudflare__AccountId=
Cloudflare__D1DatabaseId=
Cloudflare__D1ApiToken=
Cloudflare__D1Enabled=false

# --- Cloudflare R2 (object storage) ---
Cloudflare__R2AccessKeyId=
Cloudflare__R2SecretAccessKey=
Cloudflare__R2BucketName=unimarket-assets
Cloudflare__R2Endpoint=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
Cloudflare__R2PublicBaseUrl=https://pub-YOUR_BUCKET_ID.r2.dev
Cloudflare__R2Enabled=false
Cloudflare__AllowLocalUploadFallback=true

# --- Admin review queue (Cloudflare Worker / internal tools) ---
Admin__ApiKey=change-me-to-a-long-random-secret
