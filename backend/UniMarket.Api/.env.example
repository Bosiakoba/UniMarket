# Copy to .env locally — NEVER commit .env
# Firebase (later)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json
Firebase__ProjectId=your-project-id
Firebase__Enabled=true

# Cloudflare D1 / R2 (later)
Cloudflare__AccountId=
Cloudflare__D1DatabaseId=
Cloudflare__ApiToken=
Cloudflare__R2AccessKey=
Cloudflare__R2SecretKey=
Cloudflare__R2Bucket=unimarket-assets
